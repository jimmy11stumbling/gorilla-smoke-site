    {
      "@type": "Recipe",
      "name": "Gorilla's Famous BBQ Sauce",
      "author": {
        "@type": "Person",
        "name": "Ramiro Garza"
      },
      "datePublished": "2025-01-05",
      "description": "Our signature sweet and tangy BBQ sauce with a hint of smokiness. Perfect for brisket, ribs, or chicken.",
      "prepTime": "PT10M",
      "cookTime": "PT20M",
      "totalTime": "PT30M",
      "recipeYield": "2 cups",
      "recipeCategory": "Sauce",
      "recipeCuisine": "American, BBQ",
      "recipeIngredient": [
        "1 cup ketchup",
        "1/4 cup apple cider vinegar",
        "1/4 cup brown sugar",
        "2 tablespoons molasses",
        "1 tablespoon Worcestershire sauce",
        "1 teaspoon liquid smoke",
        "1 teaspoon garlic powder",
        "1 teaspoon onion powder",
        "1/2 teaspoon black pepper",
        "1/4 teaspoon cayenne pepper"
      ],
      "recipeInstructions": [
        {
          "@type": "HowToStep",
          "text": "Combine all ingredients in a medium saucepan."
        },
        {
          "@type": "HowToStep",
          "text": "Bring to a simmer over medium heat, stirring occasionally."
        },
        {
          "@type": "HowToStep",
          "text": "Reduce heat to low and simmer for 15-20 minutes until slightly thickened."
        },
        {
          "@type": "HowToStep",
          "text": "Allow to cool before transferring to a jar or bottle. Store in the refrigerator for up to 2 weeks."
        }
      ],
