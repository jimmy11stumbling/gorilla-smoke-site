    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What hours is Gorilla Smoke & Grill open?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our E Del Mar and Zapata Hwy locations are open daily from 11:00 AM to 10:00 PM. Our San Bernardo location is open Tuesday through Sunday from 5:00 PM to 11:00 PM and closed on Mondays. All kitchens serve food until closing time with full menus available."
          }
        },
        {
          "@type": "Question",
          "name": "Where is a good place to eat in Laredo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gorilla Smoke & Grill is one of the best restaurants in Laredo with three convenient locations: 3910 E Del Mar (956-568-0744), 608 Zapata Hwy (956-568-1450), and 3301 San Bernardo Ave (956-415-6011). We offer award-winning BBQ, Tex-Mex fusion dishes, burgers, and more in a family-friendly atmosphere with outdoor seating and a full bar."
          }
        },
        {
          "@type": "Question",
          "name": "Which Gorilla Smoke & Grill location is closest to me?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We have three locations in Laredo to serve you: North Laredo at 3910 E Del Mar, Central Laredo at 608 Zapata Hwy, and South Laredo at 3301 San Bernardo Ave. Each offers the same great food with slightly different hours - check our website for details about each location."
          }
        },
        {
          "@type": "Question",
          "name": "What's good to eat at Gorilla Smoke & Grill?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our most popular dishes include our slow-smoked brisket, fall-off-the-bone BBQ ribs, fire-grilled wings, and Tex-Mex BBQ fusion specialties. We're known for our authentic smoking techniques and house-made sauces and rubs."
          }
        },
        {
          "@type": "Question",
          "name": "Does Gorilla Smoke & Grill offer affordable lunch specials?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! We offer daily lunch specials Monday through Friday from 11:00 AM to 2:00 PM, starting at $9.99. These include a main dish, side, and drink. We're a great option for a quick, affordable lunch in Laredo with both dine-in and takeout options."
          }
        },
        {
          "@type": "Question",
          "name": "Is Gorilla Smoke & Grill good for dinner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely! We're one of Laredo's favorite dinner spots, perfect for date nights, family dinners, and group celebrations. Our dinner menu features premium smoked meats, grilled specialties, and a full bar with craft beers and cocktails. Reservations are recommended on weekends."
          }
        },
        {
          "@type": "Question",
          "name": "Does Gorilla Smoke & Grill offer catering?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we offer full-service catering for events of all sizes in Laredo and surrounding areas. Our catering menu can be customized for weddings, corporate events, parties, and special occasions. We provide setup, service, and cleanup options as well."
          }
        },
        {
          "@type": "Question",
          "name": "Does Gorilla Smoke & Grill have outdoor seating?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we have a spacious patio with comfortable outdoor seating. It's perfect for enjoying nice weather while dining. Our outdoor area also features fans for summer comfort and heating during cooler months."
          }
        },
        {
          "@type": "Question",
          "name": "Is Gorilla Smoke & Grill kid-friendly?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we're very family-friendly with a special kids' menu, high chairs, booster seats, and a welcoming atmosphere for children. Our portions are generous and many families enjoy sharing our BBQ platters."
          }
        },
        {
          "@type": "Question",
          "name": "How can I place an online order for pickup or delivery?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can place an order for pickup or delivery directly through our website by clicking the 'Order Now' button. We also offer delivery through popular food delivery apps like DoorDash, Uber Eats, and Grubhub."
          }
        },
        {
          "@type": "Question",
          "name": "Does Gorilla Smoke & Grill have happy hour specials?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! We offer happy hour Monday through Friday from 3:00 PM to 6:00 PM with discounted drinks and appetizers. We have $3 draft beers, $5 wine glasses, and $5 select appetizers. It's one of the best happy hour deals in Laredo."
          }
        }
      ]
    },
